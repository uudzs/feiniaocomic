{
    "name": "paheng/feiniaocomic",
    "description": "the new comic system",
    "type": "project",
    "keywords": [
        "comic",
        "reader",
        "novel"
    ],
    "homepage": "https://feiniao.comic.paheng.net/",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "feiniaocomic",
            "email": "uudzs@qq.com"
        }
    ],
    "require": {
        "php": ">=8.0.0",
        "topthink/framework": "^8.0",
        "topthink/think-orm": "^3.0|^4.0",
        "topthink/think-filesystem": "^2.0|^3.0",
        "topthink/think-multi-app": "^1.1",
        "topthink/think-view": "^2.0",
        "topthink/think-captcha": "^3.0",
        "topthink/think-image": "^1.0",
        "overtrue/pinyin": "^6.0",
        "phpmailer/phpmailer": "^7.0"
    },
    "require-dev": {
        "topthink/think-dumper": "^1.0",
        "topthink/think-trace": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "app\\": "app",
            "module\\": "modules"
        },
        "psr-0": {
            "": "extend/"
        },
        "files": [
            "app/helper.php"
        ]
    },
    "config": {
        "preferred-install": "dist"
    },
    "scripts": {
        "post-autoload-dump": [
            "@php think service:discover",
            "@php think vendor:publish"
        ]
    }
}
