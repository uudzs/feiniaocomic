{
    "name": "default",
    "title": "默认主题",
    "description": "Windows 11 风格主题，采用亚克力效果和圆角设计",
    "author": "飞鸟漫画系统",
    "version": "1.0.0",
    "preview": "preview.jpg",
    "screenshot": "screenshot.png",
    "tags": ["漫画", "小说", "视频", "响应式", "Win11风格"],
    "modules": ["comic", "novel", "video"],
    
    "colors": {
        "primary": "#0078d4",
        "success": "#67C23A",
        "warning": "#E6A23C",
        "danger": "#F56C6C",
        "info": "#909399",
        "bg_color": "#f3f3f3",
        "text_color": "#1a1a1a",
        "text_color_secondary": "#5f5f5f",
        "border_color": "rgba(0, 0, 0, 0.08)",
        "header_bg": "rgba(243, 243, 243, 0.85)",
        "footer_bg": "#f3f3f3",
        "footer_text": "#5f5f5f",
        "card_bg": "rgba(255, 255, 255, 0.7)",
        "price_color": "#ff4d4f",
        "vip_color": "#faad14"
    },

    "dark_colors": {
        "primary": "#0078d4",
        "success": "#67C23A",
        "warning": "#E6A23C",
        "danger": "#F56C6C",
        "info": "#909399",
        "bg_color": "#202020",
        "text_color": "#ffffff",
        "text_color_secondary": "#cccccc",
        "border_color": "rgba(255, 255, 255, 0.08)",
        "header_bg": "rgba(32, 32, 32, 0.85)",
        "footer_bg": "#202020",
        "footer_text": "#cccccc",
        "card_bg": "rgba(44, 44, 44, 0.7)",
        "price_color": "#ff4d4f",
        "vip_color": "#faad14"
    },

    "layout": {
        "header_fixed": true,
        "sidebar_collapse": false,
        "show_footer": true,
        "container_width": "1200px",
        "header_height": "48px",
        "sidebar_width": "240px",
        "border_radius": "8px",
        "card_padding": "24px",
        "grid_gap": "16px",
        "section_padding": "64px"
    },

    "typography": {
        "font_family": "'Segoe UI Variable', 'Segoe UI', -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif",
        "font_size_base": "14px",
        "font_size_small": "13px",
        "font_size_large": "16px",
        "line_height": "1.5"
    },

    "effects": {
        "backdrop_blur": "20px",
        "backdrop_saturate": "125%",
        "shadow_card": "0 2px 8px rgba(0, 0, 0, 0.04)",
        "shadow_card_hover": "0 8px 24px rgba(0, 0, 0, 0.08)",
        "shadow_dialog": "0 32px 64px rgba(0, 0, 0, 0.18)",
        "transition_fast": "0.1s ease",
        "transition_normal": "0.2s ease",
        "transition_slow": "0.3s ease"
    },

    "features": {
        "dark_mode": true,
        "rtl_support": false,
        "multi_language": true,
        "seo_optimized": true,
        "lazy_load": true,
        "infinite_scroll": false,
        "show_views": true,
        "show_likes": true,
        "enable_search": true,
        "enable_register": true,
        "enable_comment": true
    },
    
    "require": {
        "php": ">=7.4",
        "mysql": ">=5.7",
        "thinkphp": ">=6.0"
    },
    
    "license": "MIT",
    "homepage": "https://www.feiniao.com",
